# === APIs (Perplexity = engine principal) ===
# ANTHROPIC_API_KEY= (desativado - projeto usa Perplexity como API principal)
PERPLEXITY_KEY=pplx-...
# Vídeo demo hospedado no Supabase Storage (usado em prospecção e sales-server)
DEMO_VIDEO_URL=https://<seu-projeto>.supabase.co/storage/v1/object/public/public-assets/demo-video.mp4

# === Scraper Engine próprio (Oracle Cloud grátis) ===
SCRAPER_URL=https://api.seudominio.com.br
SCRAPER_API_KEY=<gerar-random-32-chars>

# === Evolution API (self-hosted Oracle VM) ===
EVOLUTION_URL=https://evolution.seudominio.com.br
EVOLUTION_API_KEY=...
EVOLUTION_INSTANCES=outbound1,outbound2,outbound3

# === Supabase Free Tier ===
SUPABASE_URL=https://<projeto>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...

# === Vercel Hobby (grátis) ===
VERCEL_TOKEN=vcp_...

# === Redis (Upstash Free ou self-hosted) ===
# Upstash: redis://default:TOKEN@HOST:PORT
# Self-hosted na Oracle VM: redis://redis:6379
REDIS_URL=redis://redis:6379

# === Resend Free (3k emails/mês) ===
RESEND_API_KEY=re_...

# === Meta WhatsApp Cloud API (oficial) ===
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_ACCESS_TOKEN=EAA...
WHATSAPP_VERIFY_TOKEN=brainram-verify-2026
DEFAULT_WHATSAPP_PROVIDER=auto   # auto | meta | evolution

# === Admin ===
ADMIN_PHONE=5519999999999

# === Google Calendar (Service Account) ===
# Opcional: pode ser configurado por tenant na coluna agents.google_service_account_json
# Preencha com o JSON completo da service account do Google Cloud:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
